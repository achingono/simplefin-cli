{
  "name": "simplefin-cli",
  "version": "0.1.0",
  "description": "CLI client for the SimpleFin Bridge Protocol",
  "main": "dist/cli.js",
  "bin": {
    "simplefin-cli": "./dist/cli.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "jest",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ]
  }
}
